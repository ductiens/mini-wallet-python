# Application
APP_NAME=Fintech FraudOps Copilot
APP_VERSION=1.0.0
DEBUG=True

# MongoDB Atlas
MONGODB_URL=mongodb+srv://<username>:<password>@<clusterName>.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=fraudops

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Agent
LLM_AGENT_ENABLED=True
LLM_AGENT_FALLBACK_TO_RULES=True

# API
API_V1_STR=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000